{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Open Next Router",
  "description": "A lightweight, DSL-driven LLM gateway for routing, compatibility transforms, and streaming normalization across providers.",
  "theme": "mint",
  "colors": {
    "primary": "#0B5FFF",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      { "type": "github", "href": "https://github.com/r9s-ai/open-next-router" },
      { "label": "Telegram", "href": "https://t.me/opennextrouter" }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Start",
            "icon": "rocket",
            "expanded": true,
            "pages": ["index", "getting-started/quickstart", "getting-started/install", "getting-started/run-from-source"]
          },
          {
            "group": "Concepts",
            "icon": "lightbulb",
            "expanded": false,
            "pages": ["concepts/why-onr", "concepts/architecture", "concepts/appname", "concepts/observability", "concepts/dashboards"]
          },
          {
            "group": "Configuration",
            "icon": "sliders",
            "expanded": false,
            "pages": ["configuration/onr-yaml", "configuration/keys-yaml", "configuration/models-yaml", "configuration/reload"]
          },
          {
            "group": "API",
            "icon": "plug",
            "expanded": false,
            "pages": ["api/overview", "api/openai-compatible", "api/gemini-native"]
          },
          {
            "group": "DSL",
            "icon": "code",
            "expanded": false,
            "pages": [
              "dsl/overview",
              "dsl/conventions",
              "dsl/include",
              "dsl/top-level",
              "dsl/match",
              "dsl/expressions",
              {
                "group": "Blocks",
                "icon": "layer-group",
                "expanded": false,
                "pages": [
                  {
                    "group": "Core Flow",
                    "icon": "route",
                    "expanded": false,
                    "pages": [
                      "dsl/blocks/upstream-config",
                      "dsl/blocks/auth",
                      "dsl/blocks/request",
                      "dsl/blocks/upstream",
                      "dsl/blocks/response",
                      "dsl/blocks/error"
                    ]
                  },
                  {
                    "group": "Data & Metadata",
                    "icon": "chart-line",
                    "expanded": false,
                    "pages": [
                      "dsl/blocks/metrics",
                      "dsl/blocks/models",
                      "dsl/blocks/balance"
                    ]
                  }
                ]
              },
              "dsl/full-reference"
            ]
          },
          {
            "group": "Reference",
            "icon": "book-open",
            "expanded": false,
            "pages": ["reference/cli", "reference/onr-admin-cli", "reference/access-log-fields", "reference/provider-config"]
          }
        ]
      }
    ]
  }
}
